<odoo>

    <template id="book_list_template" name="Book List">

        <t t-call="website.layout">

            <div class="container mt-4">

                <h1>Library Books</h1>

                <div class="row">

                    <t t-foreach="books" t-as="book">

                        <div class="col-md-4 mb-3">

                            <div class="card p-3">

                                <h3>
                                    <t t-esc="book.name"/>
                                </h3>

                                <p>
                                    <t t-esc="book.author"/>
                                </p>

                                <a t-att-href="'/library/book/%s' % book.id"
                                   class="btn btn-primary">
                                    Detail
                                </a>

                            </div>

                        </div>

                    </t>

                </div>

            </div>

        </t>

    </template>

</odoo>