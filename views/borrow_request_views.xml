<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- LIST VIEW -->
    <record id="view_borrow_request_list" model="ir.ui.view">
        <field name="name">library.borrow.request.list</field>
        <field name="model">library.borrow.request</field>

        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="email"/>
                <field name="phone"/>
                <field name="book_id"/>
                <field name="request_date"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <!-- FORM VIEW -->
    <record id="view_borrow_request_form" model="ir.ui.view">
        <field name="name">library.borrow.request.form</field>
        <field name="model">library.borrow.request</field>

        <field name="arch" type="xml">
            <form>
                <sheet>

                    <group>
                        <field name="name"/>
                        <field name="email"/>
                        <field name="phone"/>
                    </group>

                    <group>
                        <field name="book_id"/>
                        <field name="request_date"/>
                        <field name="state"/>
                    </group>

                </sheet>
            </form>
        </field>
    </record>

    <!-- ACTION -->
    <record id="action_borrow_request" model="ir.actions.act_window">
        <field name="name">Borrow Requests</field>
        <field name="res_model">library.borrow.request</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- MENU -->
    <menuitem id="menu_borrow_request"
              name="Borrow Requests"
              parent="menu_library_root"
              action="action_borrow_request"/>

</odoo>